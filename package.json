{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development GEMINI_API_KEY=$(cat .env | grep GEMINI_API_KEY | cut -d= -f2) tsx server/index.ts",
    "dev:debug": "NODE_ENV=development GEMINI_API_KEY=$(cat .env | grep GEMINI_API_KEY | cut -d= -f2) node --inspect -r tsx/register server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:analyze": "vite build --mode analyze",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "clean": "rm -rf dist node_modules/.vite",
    "db:push": "drizzle-kit push",
    "update-deps": "npm update && npm audit fix"
  },
